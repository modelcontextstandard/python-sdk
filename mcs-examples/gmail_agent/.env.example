# LLM API key (via LiteLLM -- works with OpenAI, Anthropic, etc.)
OPENAI_API_KEY=sk-...

# --- Option A: Auth0 Token Vault ---
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_REFRESH_TOKEN=the_users_refresh_token

# --- Option B: Static Google OAuth2 token ---
# Get one from https://developers.google.com/oauthplayground
# GOOGLE_ACCESS_TOKEN=ya29.xxx
